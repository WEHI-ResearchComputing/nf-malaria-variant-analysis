/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

//process configurations
process {
    withLabel:BWAAlign {
        queue='regular'
        cpus = 5
        memory={ 700.MB * task.attempt }
        time='12h'
        errorStrategy ={ 'retry'  }
        maxRetries= 5
    }

    
}
